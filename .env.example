# ===============================
# Traefik & Proxy Configuration (compose.yml)
# ===============================

# The domain where your app will be hosted 
APP_DOMAIN=listly.yourdomain.com

# The external Traefik network to connect to
TRAEFIK_NETWORK=traefik-network

# Your Traefik certificate resolver name (e.g. cloudflare, letsencrypt, myresolver)
TRAEFIK_CERT_RESOLVER=cloudflare

# Port used for local development (compose.local.yml) or internal container port
APP_PORT=3000
PORT=3000

# ===============================
# Nuxt App Setup
# ===============================
NUXT_BASE_URL=https://listly.yourdomain.com

# Port used for local development (compose.local.yml)
APP_PORT=3000

# ===============================
# Security
# ===============================

# 🚨 IMPORTANT: Change this to a random 32+ character string in production! 🚨
# Example generation: `openssl rand -hex 32`
NUXT_AUTH_SECRET=super-secret-key-replace-me-in-production

# The password used to log into the /admin dashboard
NUXT_ADMIN_PASSWORD=your-secure-admin-password

# ===============================
# Database
# ===============================

# SQLite database path (inside the container)
NUXT_DB_URL=/app/data/sqlite.db

# ===============================
# Mail Server (SMTP)
# ===============================
# Used for sending login Magic Links to users.
# Note: DO NOT use port 25 as it is often blocked. Use 587 (STARTTLS) or 465 (SMTPS).

NUXT_SMTP_HOST=mail.your-smarthost.com
NUXT_SMTP_PORT=587
NUXT_SMTP_USER=no-reply@yourdomain.com
NUXT_SMTP_PASS=your-smtp-password
